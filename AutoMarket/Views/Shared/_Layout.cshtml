@using AutoMarket.Services
@using System.Text.Json
@inject IOrderService OrdersService

@{
    var pendingCount = 0;

    if (User.IsInRole("Admin"))
    {
        pendingCount = await OrdersService.GetPendingCountAsync();
    }

    var compareCount = 0;
    var compareJson = Context.Session.GetString(ICompareService.SessionKey);

    if (!string.IsNullOrWhiteSpace(compareJson))
    {
        try
        {
            var compareIds = JsonSerializer.Deserialize<List<int>>(compareJson);
            compareCount = compareIds?.Count ?? 0;
        }
        catch
        {
            compareCount = 0;
        }
    }
}

<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AutoMarket</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/premium-dark.css" asp-append-version="true" />
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-lg pd-nav">
            <div class="pd-container">

                <a class="navbar-brand pd-brand text-white"
                   asp-controller="Home"
                   asp-action="Index">
                    🚗 AutoMarket
                </a>

                <button class="navbar-toggler text-white"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">

                    <ul class="navbar-nav ms-auto align-items-lg-center">

                        @* ===== АДМИН ===== *@
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white"
                                   asp-controller="Admin"
                                   asp-action="Index">
                                    Табло
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white"
                                   asp-controller="Cars"
                                   asp-action="Index">
                                    Обяви
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white"
                                   asp-controller="Cars"
                                   asp-action="Create">
                                    Добави кола
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white"
                                   asp-controller="CarModels"
                                   asp-action="Create">
                                    Добави модел
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white"
                                   asp-controller="Orders"
                                   asp-action="All">
                                    Резервации
                                    @if (pendingCount > 0)
                                    {
                                        <span class="badge bg-danger ms-2" style="border-radius:999px;">
                                            @pendingCount
                                        </span>
                                    }
                                </a>
                            </li>
                        }

                        @* ===== КЛИЕНТ / ГОСТ ===== *@
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white"
                                   asp-controller="Home"
                                   asp-action="Index">
                                    Начало
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white"
                                   asp-controller="Cars"
                                   asp-action="Index">
                                    Обяви
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white"
                                   asp-controller="Compare"
                                   asp-action="Index">
                                    Сравнение
                                    @if (compareCount > 0)
                                    {
                                        <span class="badge bg-warning text-dark ms-2" style="border-radius:999px;">
                                            @compareCount
                                        </span>
                                    }
                                </a>
                            </li>

                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-white"
                                       asp-controller="Favorites"
                                       asp-action="My">
                                        Любими
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-white"
                                       asp-controller="Orders"
                                       asp-action="My">
                                        Моите резервации
                                    </a>
                                </li>
                            }
                        }

                    </ul>

                    <div class="ms-lg-3">
                        <partial name="_LoginPartial" />
                    </div>

                </div>
            </div>
        </nav>
    </header>

    <div class="pd-container mt-3">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" style="border-radius:14px;">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" style="border-radius:14px;">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
    </div>

    <div class="pd-container mt-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="mt-5 pb-4 text-center" style="color:rgba(255,255,255,.5); font-size:14px;">
        <div class="pd-container">
            © 2026 AutoMarket — Premium Dark Edition
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>