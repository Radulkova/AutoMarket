@model AutoMarket.ViewModels.CarsQueryViewModel

@{
    ViewData["Title"] = "Коли";
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}

<style>
    .favorite-toggle-form,
    .compare-toggle-form {
        margin: 0;
    }

    .favorite-icon-btn {
        width: 46px;
        height: 46px;
        border: 1px solid rgba(255,255,255,.16);
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(8,12,20,.82);
        color: rgba(255,255,255,.72);
        transition: all .2s ease;
        box-shadow: 0 10px 24px rgba(0,0,0,.20);
        backdrop-filter: blur(4px);
        cursor: pointer;
    }

        .favorite-icon-btn:hover {
            transform: translateY(-1px) scale(1.03);
            color: #ffffff;
            border-color: rgba(255,255,255,.28);
            background: rgba(18,24,36,.92);
        }

        .favorite-icon-btn.is-active {
            color: #f4c542;
            border-color: rgba(244,197,66,.45);
            background: rgba(244,197,66,.12);
            box-shadow: 0 10px 24px rgba(244,197,66,.12);
        }

        .favorite-icon-btn svg {
            width: 24px;
            height: 24px;
            display: block;
        }

    .card-image-wrap {
        position: relative;
    }

    .card-favorite-floating {
        position: absolute;
        top: 12px;
        right: 12px;
        z-index: 2;
    }

    .favorite-login-link {
        position: absolute;
        top: 12px;
        right: 12px;
        z-index: 2;
        width: 46px;
        height: 46px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        background: rgba(8,12,20,.82);
        color: rgba(255,255,255,.72);
        border: 1px solid rgba(255,255,255,.16);
        box-shadow: 0 10px 24px rgba(0,0,0,.20);
        backdrop-filter: blur(4px);
        transition: all .2s ease;
    }

        .favorite-login-link:hover {
            color: #ffffff;
            border-color: rgba(255,255,255,.28);
            background: rgba(18,24,36,.92);
            transform: translateY(-1px) scale(1.03);
        }

        .favorite-login-link svg {
            width: 24px;
            height: 24px;
            display: block;
        }
</style>

<div class="pd-container">

    <div class="pd-hero">
        <h1>Налични автомобили</h1>
        <p>Търси, филтрирай и разглеждай обяви.</p>
        <div style="display:flex; gap:10px; flex-wrap:wrap;">
            <button class="pd-btn pd-btn-primary" type="button" onclick="document.getElementById('filtersCard').scrollIntoView({behavior:'smooth'})">
                Филтри
            </button>
            <a class="pd-btn" asp-action="Index">Изчисти</a>
            <a class="pd-btn" asp-controller="Compare" asp-action="Index">Към сравнението</a>
            <span style="color:rgba(255,255,255,.65); align-self:center;">Общо: @Model.TotalCount</span>
        </div>
    </div>

    <div id="filtersCard" class="pd-surface" style="padding:16px; margin-bottom:18px;">
        <div style="display:flex; align-items:center; justify-content:space-between; gap:12px; flex-wrap:wrap;">
            <div>
                <h5 style="margin:0; font-weight:800;">Търсене на автомобили</h5>
                <div style="color:rgba(255,255,255,.65); font-size:14px;">Намери перфектната кола</div>
            </div>
        </div>

        <form method="get" class="row g-3 align-items-end mt-1" id="filtersForm">
            <input type="hidden" asp-for="Page" value="1" />
            <input type="hidden" asp-for="PageSize" />

            <div class="col-md-3">
                <label class="form-label" style="color:rgba(255,255,255,.75);">Марка</label>
                <select class="form-select" asp-for="MakeId" asp-items="Model.Makes" id="makeSelect">
                    <option value="">Всички</option>
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label" style="color:rgba(255,255,255,.75);">Модел</label>
                <select class="form-select" asp-for="CarModelId" asp-items="Model.CarModels" id="modelSelect">
                    <option value="">Всички</option>
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label" style="color:rgba(255,255,255,.75);">Гориво</label>
                <select class="form-select" asp-for="FuelType">
                    <option value="">Всички</option>
                    <option value="Бензин">Бензин</option>
                    <option value="Дизел">Дизел</option>
                    <option value="Хибрид">Хибрид</option>
                    <option value="Електрическа">Електрическа</option>
                    <option value="Газ">Газ</option>
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label" style="color:rgba(255,255,255,.75);">Скорости</label>
                <select class="form-select" asp-for="Transmission">
                    <option value="">Всички</option>
                    <option value="Ръчна">Ръчна</option>
                    <option value="Автоматична">Автоматична</option>
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label" style="color:rgba(255,255,255,.75);">Год. от</label>
                <input class="form-control" asp-for="YearFrom" type="number" min="1950" max="2100" />
            </div>

            <div class="col-md-2">
                <label class="form-label" style="color:rgba(255,255,255,.75);">до</label>
                <input class="form-control" asp-for="YearTo" type="number" min="1950" max="2100" />
            </div>

            <div class="col-md-2">
                <label class="form-label" style="color:rgba(255,255,255,.75);">Цена от</label>
                <input class="form-control" asp-for="PriceFrom" type="number" min="0" />
            </div>

            <div class="col-md-2">
                <label class="form-label" style="color:rgba(255,255,255,.75);">до</label>
                <input class="form-control" asp-for="PriceTo" type="number" min="0" />
            </div>

            <div class="col-md-2">
                <label class="form-label" style="color:rgba(255,255,255,.75);">Сортиране</label>
                <select class="form-select" asp-for="Sort">
                    <option value="">Най-нови</option>
                    <option value="price_asc">Цена ↑</option>
                    <option value="price_desc">Цена ↓</option>
                    <option value="km_asc">Пробег ↑</option>
                    <option value="year_desc">Година ↓</option>
                </select>
            </div>

            <div class="col-md-2 d-grid">
                <button class="pd-btn pd-btn-primary" type="submit">Търси</button>
            </div>

            <div class="col-md-2 d-grid">
                <a class="pd-btn" asp-action="Index">Изчисти</a>
            </div>
        </form>
    </div>

    @if (!Model.Cars.Any())
    {
        <div class="pd-surface" style="padding:16px;">
            <div style="color:rgba(255,255,255,.8); font-weight:700;">Няма намерени автомобили</div>
            <div style="color:rgba(255,255,255,.65);">Пробвай с по-широки критерии или изчисти филтрите.</div>
        </div>
    }
    else
    {
        <div class="pd-grid">
            @foreach (var car in Model.Cars)
            {
                var mainImg =
                car.Images?
                .OrderByDescending(i => i.IsMain)
                .ThenBy(i => i.SortOrder)
                .FirstOrDefault()?.Url
                ?? "/img/no-car.jpg";

                var isFavorite = Model.FavoriteCarIds.Contains(car.Id);
                var favoriteTitle = isFavorite ? "Премахни от Любими" : "Добави в Любими";

                <div class="pd-card">
                    <div class="card-image-wrap">
                        <img class="pd-card-img" src="@mainImg" alt="car" />

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <div class="card-favorite-floating">
                                <form asp-controller="Favorites" asp-action="Toggle" method="post" class="favorite-toggle-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="carId" value="@car.Id" />
                                    <input type="hidden" name="returnUrl" value="@returnUrl" />

                                    <button type="submit"
                                            class="favorite-icon-btn @(isFavorite ? "is-active" : "")"
                                            title="@favoriteTitle"
                                            aria-label="@favoriteTitle">
                                        <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M12 38L16 26C17.2 22.4 20.5 20 24.3 20H39.7C43.5 20 46.8 22.4 48 26L52 38"
                                                  stroke="currentColor" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round" />
                                            <path d="M10 38H54V46C54 48.2 52.2 50 50 50H14C11.8 50 10 48.2 10 46V38Z"
                                                  stroke="currentColor" stroke-width="3.2" stroke-linejoin="round" />
                                            <path d="M20 50V54" stroke="currentColor" stroke-width="3.2" stroke-linecap="round" />
                                            <path d="M44 50V54" stroke="currentColor" stroke-width="3.2" stroke-linecap="round" />
                                            <circle cx="18" cy="43" r="2.6" fill="currentColor" />
                                            <circle cx="46" cy="43" r="2.6" fill="currentColor" />
                                            <path d="M22 20L26 12H38L42 20" stroke="currentColor" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round" />
                                        </svg>
                                    </button>
                                </form>
                            </div>
                        }
                        else
                        {
                            <a class="favorite-login-link"
                               asp-area="Identity"
                               asp-page="/Account/Login"
                               title="Влез, за да добавяш в Любими"
                               aria-label="Влез, за да добавяш в Любими">
                                <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M12 38L16 26C17.2 22.4 20.5 20 24.3 20H39.7C43.5 20 46.8 22.4 48 26L52 38"
                                          stroke="currentColor" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round" />
                                    <path d="M10 38H54V46C54 48.2 52.2 50 50 50H14C11.8 50 10 48.2 10 46V38Z"
                                          stroke="currentColor" stroke-width="3.2" stroke-linejoin="round" />
                                    <path d="M20 50V54" stroke="currentColor" stroke-width="3.2" stroke-linecap="round" />
                                    <path d="M44 50V54" stroke="currentColor" stroke-width="3.2" stroke-linecap="round" />
                                    <circle cx="18" cy="43" r="2.6" fill="currentColor" />
                                    <circle cx="46" cy="43" r="2.6" fill="currentColor" />
                                    <path d="M22 20L26 12H38L42 20" stroke="currentColor" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                            </a>
                        }
                    </div>

                    <div class="pd-card-body">
                        <div class="pd-title">@car.CarModel.Make.Name @car.CarModel.Name</div>

                        <div class="pd-badges">
                            <span class="pd-badge">@car.Year</span>
                            <span class="pd-badge">@car.MileageKm.ToString("N0") км</span>
                            <span class="pd-badge">@car.FuelType</span>
                            <span class="pd-badge">@car.Transmission</span>
                        </div>

                        <div class="pd-price">@car.Price.ToString("N0") €</div>

                        <div style="display:grid; gap:8px;">
                            <a class="pd-btn" asp-action="Details" asp-route-id="@car.Id">Виж детайли</a>

                            <form asp-controller="Compare" asp-action="Add" method="post" class="compare-toggle-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="carId" value="@car.Id" />
                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                <button type="submit" class="pd-btn pd-btn-primary" style="width:100%;">
                                    Добави за сравнение
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="mt-4">
                <ul class="pagination justify-content-center">

                    <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-MakeId="@Model.MakeId"
                           asp-route-CarModelId="@Model.CarModelId"
                           asp-route-FuelType="@Model.FuelType"
                           asp-route-Transmission="@Model.Transmission"
                           asp-route-YearFrom="@Model.YearFrom"
                           asp-route-YearTo="@Model.YearTo"
                           asp-route-PriceFrom="@Model.PriceFrom"
                           asp-route-PriceTo="@Model.PriceTo"
                           asp-route-Sort="@Model.Sort"
                           asp-route-Page="@(Model.Page - 1)"
                           asp-route-PageSize="@Model.PageSize">←</a>
                    </li>

                    @for (int p = 1; p <= Model.TotalPages; p++)
                    {
                        <li class="page-item @(p == Model.Page ? "active" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-MakeId="@Model.MakeId"
                               asp-route-CarModelId="@Model.CarModelId"
                               asp-route-FuelType="@Model.FuelType"
                               asp-route-Transmission="@Model.Transmission"
                               asp-route-YearFrom="@Model.YearFrom"
                               asp-route-YearTo="@Model.YearTo"
                               asp-route-PriceFrom="@Model.PriceFrom"
                               asp-route-PriceTo="@Model.PriceTo"
                               asp-route-Sort="@Model.Sort"
                               asp-route-Page="@p"
                               asp-route-PageSize="@Model.PageSize">@p</a>
                        </li>
                    }

                    <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-MakeId="@Model.MakeId"
                           asp-route-CarModelId="@Model.CarModelId"
                           asp-route-FuelType="@Model.FuelType"
                           asp-route-Transmission="@Model.Transmission"
                           asp-route-YearFrom="@Model.YearFrom"
                           asp-route-YearTo="@Model.YearTo"
                           asp-route-PriceFrom="@Model.PriceFrom"
                           asp-route-PriceTo="@Model.PriceTo"
                           asp-route-Sort="@Model.Sort"
                           asp-route-Page="@(Model.Page + 1)"
                           asp-route-PageSize="@Model.PageSize">→</a>
                    </li>

                </ul>
            </nav>
        }
    }
</div>

@section Scripts {
    <script>
        (function () {
            const makeSelect = document.getElementById('makeSelect');
            const modelSelect = document.getElementById('modelSelect');

            async function loadModels(makeId, selectedModelId) {
                modelSelect.innerHTML = '';
                const optAll = document.createElement('option');
                optAll.value = '';
                optAll.textContent = 'Всички';
                modelSelect.appendChild(optAll);

                if (!makeId) return;

                const resp = await fetch(`/Cars/ModelsByMake?makeId=${encodeURIComponent(makeId)}`);
                if (!resp.ok) return;

                const data = await resp.json();
                for (const m of data) {
                    const opt = document.createElement('option');
                    opt.value = m.id;
                    opt.textContent = m.name;
                    if (selectedModelId && String(selectedModelId) === String(m.id)) {
                        opt.selected = true;
                    }
                    modelSelect.appendChild(opt);
                }
            }

            makeSelect.addEventListener('change', async function () {
                await loadModels(makeSelect.value, null);
            });

            const selectedModel = modelSelect.value;
            if (makeSelect.value) {
                loadModels(makeSelect.value, selectedModel);
            }
        })();
    </script>
}