@model AutoMarket.Models.Car
@using AutoMarket.Models
@using System.Linq

@{
    ViewData["Title"] = $"{Model.CarModel.Make.Name} {Model.CarModel.Name}";

    var mainImg =
        Model.Images?
            .OrderByDescending(i => i.IsMain)
            .ThenBy(i => i.SortOrder)
            .FirstOrDefault()?.Url
        ?? (string.IsNullOrWhiteSpace(Model.ImageUrl) ? "/img/no-car.jpg" : Model.ImageUrl);

    var gallery = (Model.Images ?? Enumerable.Empty<CarImage>())
        .OrderByDescending(i => i.IsMain)
        .ThenBy(i => i.SortOrder)
        .ToList();

    var sellerName = Model.Seller?.UserName ?? "Продавач";
    var sellerEmail = Model.Seller?.Email;
    var sellerPhone = Model.Seller?.PhoneNumber;
    var isFavorite = ViewBag.IsFavorite is bool value && value;
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
    var favoriteTitle = isFavorite ? "Премахни от Любими" : "Добави в Любими";
}

<style>
    .favorite-toggle-form,
    .compare-toggle-form {
        margin: 0;
    }

    .favorite-icon-btn {
        width: 52px;
        height: 52px;
        border: 1px solid rgba(255,255,255,.16);
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(8,12,20,.82);
        color: rgba(255,255,255,.72);
        transition: all .2s ease;
        box-shadow: 0 10px 24px rgba(0,0,0,.20);
        backdrop-filter: blur(4px);
        cursor: pointer;
    }

        .favorite-icon-btn:hover {
            transform: translateY(-1px) scale(1.03);
            color: #ffffff;
            border-color: rgba(255,255,255,.28);
            background: rgba(18,24,36,.92);
        }

        .favorite-icon-btn.is-active {
            color: #f4c542;
            border-color: rgba(244,197,66,.45);
            background: rgba(244,197,66,.12);
            box-shadow: 0 10px 24px rgba(244,197,66,.12);
        }

        .favorite-icon-btn svg {
            width: 26px;
            height: 26px;
            display: block;
        }

    .compare-highlight-btn {
        min-height: 52px;
        padding: 0 18px;
        border-radius: 12px;
        border: 1px solid rgba(80, 210, 255, .35);
        background: linear-gradient(135deg, rgba(0, 153, 255, .95), rgba(0, 200, 255, .88));
        color: #ffffff;
        font-weight: 800;
        box-shadow: 0 10px 24px rgba(0, 153, 255, .22);
        transition: all .2s ease;
    }

        .compare-highlight-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 14px 28px rgba(0, 153, 255, .28);
            filter: brightness(1.05);
        }

        .compare-highlight-btn:focus,
        .compare-highlight-btn:active {
            color: #ffffff;
        }

    .details-top-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        align-items: center;
    }
</style>

<div class="pd-container">

    <div class="pd-hero" style="margin-bottom:16px;">
        <h1 style="margin-bottom:6px;">@Model.CarModel.Make.Name @Model.CarModel.Name</h1>
        <p style="margin-bottom:0;">
            @Model.Year • @Model.MileageKm.ToString("N0") км • @Model.FuelType • @Model.Transmission
        </p>
    </div>

    @if (Model.IsSold)
    {
        <div class="alert alert-danger" style="border-radius:14px;">
            Продаден автомобил
        </div>
    }

    <div class="pd-grid" style="align-items:start;">

        <div style="grid-column: span 7;">
            <div class="pd-surface" style="padding:14px;">
                <img id="mainCarImg"
                     src="@mainImg"
                     alt="Car image"
                     style="width:100%; height:420px; object-fit:cover; border-radius:16px; border:1px solid rgba(255,255,255,.10);" />

                @if (gallery.Count > 1)
                {
                    <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:12px;">
                        @foreach (var img in gallery)
                        {
                            <button type="button"
                                    class="pd-btn"
                                    style="padding:6px; border-radius:14px;"
                                    onclick="setMainImg('@img.Url')">
                                <img src="@img.Url"
                                     alt="thumb"
                                     style="width:84px; height:60px; object-fit:cover; border-radius:10px; border:1px solid rgba(255,255,255,.10);" />
                            </button>
                        }
                    </div>
                }
                else
                {
                    <div style="margin-top:10px; color:rgba(255,255,255,.6); font-size:14px;">
                        Няма добавени допълнителни снимки към тази обява.
                    </div>
                }
            </div>
        </div>

        <div style="grid-column: span 5;">
            <div class="pd-surface" style="padding:16px; margin-bottom:16px;">
                <div style="display:flex; align-items:center; justify-content:space-between; gap:12px;">
                    <div style="color:rgba(255,255,255,.7); font-size:14px;">Цена</div>
                    <div class="pd-price" style="margin:0;">@Model.Price.ToString("N0") €</div>
                </div>

                <div style="margin-top:14px; display:flex; gap:10px; flex-wrap:wrap;">
                    <span class="pd-badge">Година: <b style="color:rgba(255,255,255,.9)">@Model.Year</b></span>
                    <span class="pd-badge">Пробег: <b style="color:rgba(255,255,255,.9)">@Model.MileageKm.ToString("N0") км</b></span>
                    <span class="pd-badge">Гориво: <b style="color:rgba(255,255,255,.9)">@Model.FuelType</b></span>
                    <span class="pd-badge">Скорости: <b style="color:rgba(255,255,255,.9)">@Model.Transmission</b></span>
                    <span class="pd-badge">Двигател: <b style="color:rgba(255,255,255,.9)">@Model.EngineCapacityCc cc</b></span>
                    <span class="pd-badge">Мощност: <b style="color:rgba(255,255,255,.9)">@Model.HorsePower hp</b></span>
                </div>

                <div class="details-top-actions" style="margin-top:16px;">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <form asp-controller="Favorites" asp-action="Toggle" method="post" class="favorite-toggle-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="carId" value="@Model.Id" />
                            <input type="hidden" name="returnUrl" value="@returnUrl" />

                            <button type="submit"
                                    class="favorite-icon-btn @(isFavorite ? "is-active" : "")"
                                    title="@favoriteTitle"
                                    aria-label="@favoriteTitle">
                                <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M12 38L16 26C17.2 22.4 20.5 20 24.3 20H39.7C43.5 20 46.8 22.4 48 26L52 38"
                                          stroke="currentColor" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round" />
                                    <path d="M10 38H54V46C54 48.2 52.2 50 50 50H14C11.8 50 10 48.2 10 46V38Z"
                                          stroke="currentColor" stroke-width="3.2" stroke-linejoin="round" />
                                    <path d="M20 50V54" stroke="currentColor" stroke-width="3.2" stroke-linecap="round" />
                                    <path d="M44 50V54" stroke="currentColor" stroke-width="3.2" stroke-linecap="round" />
                                    <circle cx="18" cy="43" r="2.6" fill="currentColor" />
                                    <circle cx="46" cy="43" r="2.6" fill="currentColor" />
                                    <path d="M22 20L26 12H38L42 20" stroke="currentColor" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                            </button>
                        </form>

                        <form asp-controller="Compare" asp-action="Add" method="post" class="compare-toggle-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="carId" value="@Model.Id" />
                            <input type="hidden" name="returnUrl" value="@returnUrl" />
                            <button type="submit" class="compare-highlight-btn">
                                Добави за сравнение
                            </button>
                        </form>

                        if (!Model.IsSold)
                        {
                            <button type="button"
                                    class="btn btn-warning"
                                    style="border-radius:12px; min-height:52px; padding-inline:18px;"
                                    data-bs-toggle="modal"
                                    data-bs-target="#reserveViewingModal">
                                Резервирай оглед
                            </button>
                        }
                        else
                        {
                            <div style="margin-top:8px; color:rgba(255,255,255,.75); font-size:14px;">
                                Не може да резервирате оглед — автомобилът е продаден.
                            </div>
                        }
                    }
                    else
                    {
                        <div style="display:flex; gap:10px; flex-wrap:wrap;">
                            <form asp-controller="Compare" asp-action="Add" method="post" class="compare-toggle-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="carId" value="@Model.Id" />
                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                <button type="submit" class="compare-highlight-btn">
                                    Добави за сравнение
                                </button>
                            </form>

                            <p style="margin:0; align-self:center;">
                                <a asp-area="Identity" asp-page="/Account/Login">Влез</a>, за да добавиш в Любими и да резервираш оглед.
                            </p>
                        </div>
                    }
                </div>

                <div style="margin-top:14px; display:flex; gap:10px; flex-wrap:wrap;">
                    <a class="pd-btn pd-btn-primary" asp-controller="Cars" asp-action="Index">← Назад към обявите</a>

                    <a class="pd-btn" asp-controller="Compare" asp-action="Index">Към сравнението</a>

                    <button type="button" class="pd-btn pd-btn-primary"
                            data-bs-toggle="modal" data-bs-target="#contactSellerModal">
                        Свържи се с продавача
                    </button>

                    @if (User.IsInRole("Admin"))
                    {
                        <a class="pd-btn" asp-controller="Cars" asp-action="Edit" asp-route-id="@Model.Id">Редактирай</a>
                    }
                </div>
            </div>

            <div class="pd-surface" style="padding:16px;">
                <div style="font-weight:800; margin-bottom:8px;">Описание</div>

                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    <div style="color:rgba(255,255,255,.78); line-height:1.55;">
                        @Model.Description
                    </div>
                }
                else
                {
                    <div style="color:rgba(255,255,255,.6);">
                        Няма добавено описание.
                    </div>
                }

                @if (User.IsInRole("Admin"))
                {
                    <div style="margin-top:14px; display:flex; gap:10px; flex-wrap:wrap;">
                        <form asp-controller="Cars"
                              asp-action="Delete"
                              asp-route-id="@Model.Id"
                              method="post"
                              onsubmit="return confirm('Сигурна ли си, че искаш да изтриеш тази обява?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="pd-btn" style="border-color:rgba(255,80,80,.35);">
                                Изтрий
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="reserveViewingModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content pd-surface" style="padding:14px;">
            <div class="modal-header" style="border-bottom:1px solid rgba(255,255,255,.10);">
                <h5 class="modal-title" style="color:rgba(255,255,255,.92); font-weight:800;">
                    Резервирай оглед
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Затвори"></button>
            </div>

            <form asp-controller="Orders" asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="CarId" value="@Model.Id" />

                <div class="modal-body" style="color:rgba(255,255,255,.82);">
                    <div style="margin-bottom:10px; color:rgba(255,255,255,.65); font-size:14px;">
                        Обява:
                        <b style="color:rgba(255,255,255,.90);">@Model.CarModel.Make.Name @Model.CarModel.Name</b>
                        (@Model.Year)
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Име</label>
                        <input class="form-control" name="FirstName" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Фамилия</label>
                        <input class="form-control" name="LastName" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Телефон</label>
                        <input class="form-control" name="Phone" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Бележка (по желание)</label>
                        <textarea class="form-control" name="Note" rows="3"></textarea>
                    </div>

                    <div style="margin-top:8px; color:rgba(255,255,255,.60); font-size:12px;">
                        Данните се използват само за връзка с теб относно огледа.
                    </div>
                </div>

                <div class="modal-footer" style="border-top:1px solid rgba(255,255,255,.10);">
                    <button type="button" class="pd-btn" data-bs-dismiss="modal">Отказ</button>
                    <button type="submit" class="btn btn-warning" style="border-radius:12px;">
                        Потвърди резервацията
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>

<div class="modal fade" id="contactSellerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content pd-surface" style="padding:14px;">
            <div class="modal-header" style="border-bottom:1px solid rgba(255,255,255,.10);">
                <h5 class="modal-title" style="color:rgba(255,255,255,.92); font-weight:800;">
                    Свържи се с продавача
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Затвори"></button>
            </div>

            <div class="modal-body" style="color:rgba(255,255,255,.82);">
                <div style="margin-bottom:10px; color:rgba(255,255,255,.65); font-size:14px;">
                    Относно обявата:
                    <b style="color:rgba(255,255,255,.90);">@Model.CarModel.Make.Name @Model.CarModel.Name</b>
                    (@Model.Year)
                </div>

                <div class="pd-surface" style="padding:12px; box-shadow:none;">
                    <div style="display:grid; gap:10px;">
                        <div>
                            <div style="color:rgba(255,255,255,.60); font-size:13px;">Продавач</div>
                            <div style="font-weight:750;">@sellerName</div>
                        </div>

                        <div>
                            <div style="color:rgba(255,255,255,.60); font-size:13px;">Телефон</div>
                            <div style="font-weight:750;">
                                @(string.IsNullOrWhiteSpace(sellerPhone) ? "Няма добавен телефон" : sellerPhone)
                            </div>
                        </div>

                        <div>
                            <div style="color:rgba(255,255,255,.60); font-size:13px;">Имейл</div>
                            <div style="font-weight:750;">
                                @(string.IsNullOrWhiteSpace(sellerEmail) ? "Няма добавен имейл" : sellerEmail)
                            </div>
                        </div>
                    </div>
                </div>

                <div style="margin-top:14px; display:flex; gap:10px; flex-wrap:wrap;">
                    @if (!string.IsNullOrWhiteSpace(sellerPhone))
                    {
                        <a class="pd-btn pd-btn-primary" href="tel:@sellerPhone">Обади се</a>
                    }
                    @if (!string.IsNullOrWhiteSpace(sellerEmail))
                    {
                        <a class="pd-btn"
                           href="mailto:@sellerEmail?subject=Запитване%20за%20автомобил&body=Здравейте,%0AИнтересувам%20се%20от%20обявата:%20@Model.CarModel.Make.Name%20@Model.CarModel.Name%20(@Model.Year).">
                            Изпрати имейл
                        </a>
                    }
                    <button type="button" class="pd-btn" data-bs-dismiss="modal">Затвори</button>
                </div>

                <div style="margin-top:10px; color:rgba(255,255,255,.55); font-size:12px;">
                    Съвет: уговаряй оглед на безопасно място и не изпращай чувствителни данни.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function setMainImg(url) {
            const img = document.getElementById('mainCarImg');
            if (!img) return;
            img.src = url;
        }
    </script>
}