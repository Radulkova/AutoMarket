@page
@model LoginModel

@{
    ViewData["Title"] = "Вход";
}

<div class="pd-container" style="max-width: 1000px; margin-top: 40px;">

    <div class="pd-surface" style="padding: 28px;">
        <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 32px; align-items:start;">

            <div>
                <h1 style="margin-bottom: 10px;">Вход</h1>
                <h4 style="margin-bottom: 20px; color: rgba(255,255,255,.72); font-weight:600;">
                    Влез в своя профил
                </h4>

                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert" style="margin-bottom:14px;"></div>

                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label">Имейл</label>
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="Въведи имейл" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label">Парола</label>
                        <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Въведи парола" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="mb-3 form-check">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label asp-for="Input.RememberMe" class="form-check-label">Запомни ме</label>
                    </div>

                    <div class="d-grid mb-3">
                        <button id="login-submit" type="submit" class="pd-btn pd-btn-primary">
                            Вход
                        </button>
                    </div>

                    <div style="display:grid; gap:10px;">
                        <a id="forgot-password" asp-page="./ForgotPassword">Забравена парола?</a>
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Нямаш акаунт? Регистрирай се</a>
                        <a asp-page="./ResendEmailConfirmation">Изпрати отново потвърждение за имейл</a>
                    </div>
                </form>
            </div>

            <div>
                <div class="pd-hero" style="padding: 22px; margin:0;">
                    <div class="pd-badge" style="margin-bottom: 12px;">AutoMarket</div>

                    <h3 style="margin-bottom: 12px; font-weight: 900;">
                        Добре дошъл отново
                    </h3>

                    <p style="color: rgba(255,255,255,.76); margin-bottom: 18px; line-height: 1.65;">
                        Влез в системата, за да управляваш профила си, любимите обяви, сравненията и резервациите си по-бързо и удобно.
                    </p>

                    <div style="display:grid; gap:12px;">
                        <div class="pd-surface" style="padding:14px; box-shadow:none;">
                            <div style="color:rgba(255,255,255,.62); font-size:13px;">Достъп</div>
                            <div style="font-weight:800; margin-top:4px;">До любими обяви и сравнения</div>
                        </div>

                        <div class="pd-surface" style="padding:14px; box-shadow:none;">
                            <div style="color:rgba(255,255,255,.62); font-size:13px;">Удобство</div>
                            <div style="font-weight:800; margin-top:4px;">По-бързи резервации и управление</div>
                        </div>

                        <div class="pd-surface" style="padding:14px; box-shadow:none;">
                            <div style="color:rgba(255,255,255,.62); font-size:13px;">Сигурност</div>
                            <div style="font-weight:800; margin-top:4px;">Личен профил с защитен достъп</div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}